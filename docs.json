{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "2Boys Wholesale B2B Suite",
  "description": "Merchant guide for 2Boys Wholesale B2B Suite — wholesale groups, pricing, registration forms, and storefront setup on Shopify.",
  "colors": {
    "primary": "#5B21B6",
    "light": "#A78BFA",
    "dark": "#4C1D95"
  },
  "fonts": {
    "heading": {
      "family": "Fraunces",
      "weight": 500
    },
    "body": {
      "family": "Inter"
    }
  },
  "favicon": "/favicon.ico",
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "contextual": {
    "options": ["copy", "view", "assistant", "mcp", "add-mcp"]
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Home",
          "icon": "house",
          "href": "/"
        },
        {
          "anchor": "Changelog",
          "icon": "scroll-text",
          "href": "https://www.mintlify.com/docs/changelog"
        },
        {
          "anchor": "Help",
          "icon": "life-buoy",
          "href": "https://www.mintlify.com/docs/contact-support"
        }
      ]
    },
    "directory": "card",
    "products": [
      {
        "product": "Wholesale B2B Suite",
        "description": "Merchant guide — set up wholesale groups, pricing, and applications on Shopify.",
        "icon": "store",
        "groups": [
          {
            "group": "Get started",
            "expanded": true,
            "root": "getting-started/index",
            "pages": [
              "getting-started/install",
              "getting-started/onboarding-checklist",
              "getting-started/key-concepts"
            ]
          },
          {
            "group": "Wholesale groups",
            "expanded": true,
            "root": "groups/index",
            "pages": [
              "groups/create-a-group",
              "groups/manage-customers"
            ]
          },
          {
            "group": "Pricing",
            "expanded": true,
            "root": "pricing/index",
            "pages": [
              "pricing/price-rules",
              "pricing/volume-tiers"
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [],
    "primary": {
      "type": "button",
      "label": "Open Shopify Admin",
      "href": "https://admin.shopify.com"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/yourcompany",
      "linkedin": "https://linkedin.com/company/yourcompany"
    }
  }
}
